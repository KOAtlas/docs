---
import Layout from "../../components/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const docs = await getCollection("docs");

  const sorted = [...docs].sort((a, b) => {
    const gCmp = a.data.group.localeCompare(b.data.group);
    return gCmp !== 0 ? gCmp : a.data.sidebar.order - b.data.sidebar.order;
  });

  return sorted.map((doc, i) => ({
    params: { slug: doc.id },
    props: {
      doc,
      prev: sorted[i - 1] ?? null,
      next: sorted[i + 1] ?? null,
    },
  }));
}

type Doc = Awaited<ReturnType<typeof getCollection<"docs">>>[number];

interface Props {
  doc: Doc;
  prev: Doc | null;
  next: Doc | null;
}

const { doc, prev, next } = Astro.props;
const { Content, headings } = await render(doc);
const currentPath = `/docs/${doc.id}`;
---

<Layout
  title={doc.data.title}
  description={doc.data.description ?? ""}
  currentPath={currentPath}
  headings={headings}
>
  <article class="prose prose-ko max-w-none">
    <Content />
  </article>

  {(prev || next) && (
    <nav class="mt-12 pt-6 border-t border-cream-200 flex items-stretch gap-3">
      {prev ? (
        <a
          href={`/docs/${prev.id}`}
          class="group flex-1 flex flex-col gap-1 px-4 py-3 rounded-lg border border-cream-200 hover:border-ko-amber hover:bg-cream-100 transition-all duration-150 no-underline"
        >
          <span class="text-[10px] font-mono font-semibold uppercase tracking-widest text-ko-muted group-hover:text-ko-amber transition-colors flex items-center gap-1">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" class="shrink-0">
              <path d="M7.5 2L3.5 6L7.5 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Previous
          </span>
          <span class="text-sm font-medium text-ko-brown font-mono truncate">
            {prev.data.sidebar.label}
          </span>
          <span class="text-[10px] text-ko-muted font-mono">{prev.data.group}</span>
        </a>
      ) : (
        <div class="flex-1" />
      )}

      {next ? (
        <a
          href={`/docs/${next.id}`}
          class="group flex-1 flex flex-col gap-1 px-4 py-3 rounded-lg border border-cream-200 hover:border-ko-amber hover:bg-cream-100 transition-all duration-150 no-underline text-right items-end"
        >
          <span class="text-[10px] font-mono font-semibold uppercase tracking-widest text-ko-muted group-hover:text-ko-amber transition-colors flex items-center gap-1">
            Next
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" class="shrink-0">
              <path d="M4.5 2L8.5 6L4.5 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <span class="text-sm font-medium text-ko-brown font-mono truncate">
            {next.data.sidebar.label}
          </span>
          <span class="text-[10px] text-ko-muted font-mono">{next.data.group}</span>
        </a>
      ) : (
        <div class="flex-1" />
      )}
    </nav>
  )}
</Layout>