---
import { getCollection } from "astro:content";

const { currentPath = "/" } = Astro.props;
const docs = await getCollection("docs");

const groups: Record<string, (typeof docs)[number][]> = {};

for (const doc of docs) {
  const group = doc.data.group;

  if (!groups[group]) {
    groups[group] = [];
  }

  groups[group].push(doc);
}

for (const group in groups) {
  groups[group].sort((a, b) => a.data.sidebar.order - b.data.sidebar.order);
}
---

<aside class="hidden lg:block w-56 shrink-0 sticky top-12 self-start h-[calc(100vh-3rem)] overflow-y-auto py-8 pr-6 border-r border-cream-200">
  {Object.entries(groups).map(([group, pages]) => (
    <div class="mb-8">
      <p class="text-[10px] font-mono font-semibold text-ko-muted uppercase tracking-widest mb-2 px-3">
        {group}
      </p>
      <nav class="flex flex-col gap-0.5 text-sm">
        {pages.map((page) => {
          const href = `/docs/${page.id}`;
          const active = href === currentPath;
          return (
            <a
              href={href}
              class={
                `px-3 py-1.5 rounded-r text-sm transition-all duration-150 ease-in-out ${
                  active
                    ? "bg-cream-100 text-ko-brown font-medium border-l-2 border-ko-amber pl-[calc(0.75rem-2px)]"
                    : "text-ko-muted hover:text-ko-brown hover:bg-cream-100"
                }`
              }
            >
              {page.data.sidebar.label}
            </a>
          );
        })}
      </nav>
    </div>
  ))}
</aside>
